// ─── ELECTRICAL TOOL SYSTEM ───────────────────────────────────────────────────

let currentTool = 'select';
let electricalElements = [];
let selectedEl = null;
let dragging = null;
let dragOffset = {x:0,y:0};
let pendingNotePos = null;

const ELEC_TYPES = {
  outlet: { label: 'OUTLET', shape: 'circle', r: 8, cls: 'elec-outlet' },
  gfci:   { label: 'GFCI',   shape: 'circle', r: 8, cls: 'elec-gfci'   },
  switch: { label: 'SW',     shape: 'rect',   cls: 'elec-switch'  },
  light:  { label: 'LIGHT',  shape: 'star',   cls: 'elec-light'   },
  fan:    { label: 'FAN',    shape: 'cross',  cls: 'elec-fan'     },
};

function setTool(t) {
  currentTool = t;
  document.querySelectorAll('.tool-btn').forEach(b=>b.classList.remove('active'));
  const btn = document.getElementById('btn-'+t);
  if (btn) btn.classList.add('active');
  document.getElementById('status-tool').textContent = 'TOOL: ' + t.toUpperCase();
  svg.style.cursor = t === 'select' ? 'default' : t === 'delete' ? 'crosshair' : 'crosshair';
}
setTool('select');

function getSVGPoint(e) {
  const rect = svg.getBoundingClientRect();
  return { x: e.clientX - rect.left, y: e.clientY - rect.top };
}

function drawElecElement(elData) {
  const g = el('g', {class:'elec-element', transform:`translate(${elData.x},${elData.y})`}, layerElec);
  g.dataset.id = elData.id;
  const type = ELEC_TYPES[elData.type];
  if (!type) {
    // note type
    const t = el('text',{x:0,y:0,fill:'#ffff80','font-family':'Share Tech Mono, monospace','font-size':'9px','font-style':'italic'},g);
    t.textContent = '✎ ' + elData.label;
    g.appendChild(t);
    setupElecInteraction(g, elData);
    return g;
  }
  if (type.shape === 'circle') {
    el('circle',{cx:0,cy:0,r:type.r,class:type.cls},g);
    const t = el('text',{x:0,y:type.r+9,class:'elec-label'},g);
    t.textContent = type.label;
  } else if (type.shape === 'rect') {
    el('rect',{x:-8,y:-6,width:16,height:12,class:type.cls},g);
    const t = el('text',{x:0,y:14,class:'elec-label'},g);
    t.textContent = type.label;
  } else if (type.shape === 'star') {
    el('circle',{cx:0,cy:0,r:9,class:type.cls},g);
    el('text',{x:0,y:3,class:'elec-label','text-anchor':'middle','dominant-baseline':'middle',fill:'#0a0a00','font-size':'10px'},g).textContent='✦';
    const t = el('text',{x:0,y:18,class:'elec-label'},g);
    t.textContent = type.label;
  } else if (type.shape === 'cross') {
    el('circle',{cx:0,cy:0,r:9,class:type.cls},g);
    el('text',{x:0,y:3,class:'elec-label','text-anchor':'middle','dominant-baseline':'middle',fill:'#001a2a','font-size':'12px'},g).textContent='⊕';
    const t = el('text',{x:0,y:18,class:'elec-label'},g);
    t.textContent = type.label;
  }
  if (elData.note) {
    const t = el('text',{x:12,y:-8,class:'elec-label','text-anchor':'start',fill:'#ffff80'},g);
    t.textContent = elData.note;
  }
  setupElecInteraction(g, elData);
  return g;
}

function setupElecInteraction(g, elData) {
  g.addEventListener('mousedown', e => {
    if (currentTool === 'delete') {
      removeElement(elData.id);
      e.stopPropagation(); return;
    }
    e.stopPropagation();
    dragging = elData;
    const pt = getSVGPoint(e);
    dragOffset = {x: pt.x - elData.x, y: pt.y - elData.y};
    if (selectedEl) selectedEl.classList.remove('selected');
    selectedEl = g;
    g.classList.add('selected');
  });
  g.addEventListener('contextmenu', e => {
    e.preventDefault();
    removeElement(elData.id);
  });
}

function removeElement(id) {
  electricalElements = electricalElements.filter(e=>e.id!==id);
  const g = layerElec.querySelector(`[data-id="${id}"]`);
  if (g) g.remove();
  updateCount();
}

svg.addEventListener('click', e => {
  if (currentTool === 'select' || currentTool === 'delete') return;
  const pt = getSVGPoint(e);
  if (currentTool === 'note') {
    pendingNotePos = pt;
    const ni = document.getElementById('note-input');
    ni.style.display = 'flex';
    ni.style.left = (e.clientX+10)+'px';
    ni.style.top = (e.clientY-40)+'px';
    document.getElementById('note-text').value = '';
    document.getElementById('note-text').focus();
    return;
  }
  addElecElement(currentTool, pt.x, pt.y);
});

svg.addEventListener('mousemove', e => {
  const pt = getSVGPoint(e);
  document.getElementById('status-pos').textContent =
    `POS: ${Math.round(pt.x/S)}" , ${Math.round(pt.y/S)}"`;
  if (dragging) {
    const nx = pt.x - dragOffset.x;
    const ny = pt.y - dragOffset.y;
    dragging.x = nx; dragging.y = ny;
    const g = layerElec.querySelector(`[data-id="${dragging.id}"]`);
    if (g) g.setAttribute('transform', `translate(${nx},${ny})`);
  }
});

document.addEventListener('mouseup', () => { dragging = null; });

let elecIdCounter = 0;
function addElecElement(type, x, y) {
  const id = 'e' + (++elecIdCounter);
  const elData = {id, type, x, y, label: ELEC_TYPES[type]?.label || type};
  electricalElements.push(elData);
  drawElecElement(elData);
  updateCount();
}

function updateCount() {
  document.getElementById('status-count').textContent =
    'ELECTRICAL ELEMENTS: ' + electricalElements.length;
}

function confirmNote() {
  const txt = document.getElementById('note-text').value.trim();
  if (txt && pendingNotePos) {
    const id = 'n' + (++elecIdCounter);
    const elData = {id, type:'note', x:pendingNotePos.x, y:pendingNotePos.y, label:txt};
    electricalElements.push(elData);
    drawElecElement(elData);
    updateCount();
  }
  document.getElementById('note-input').style.display = 'none';
  pendingNotePos = null;
}
function cancelNote() {
  document.getElementById('note-input').style.display = 'none';
  pendingNotePos = null;
}
document.getElementById('note-text').addEventListener('keydown', e => {
  if (e.key==='Enter') confirmNote();
  if (e.key==='Escape') cancelNote();
});

function printBlueprint() {
  window.print();
}

